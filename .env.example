# ── Обязательно задать перед деплоем ──────────────────────────────
# Секрет для подписи сессионных JWT. Сгенерируй: openssl rand -base64 48
AUTH_SECRET=change-me-to-a-long-random-string

# Учётка администратора (используется скриптом seed один раз для создания хэша)
ADMIN_USERNAME=marianna
ADMIN_PASSWORD=change-me-strong-password

# ── Опционально ───────────────────────────────────────────────────
# Postgres для продакшена (Render/Neon). Если пусто — используется
# локальное JSON-хранилище data/db.json (только для разработки).
DATABASE_URL=

# Контакт для кнопки "Узнать об объекте"
NEXT_PUBLIC_CONTACT_URL=https://www.instagram.com/marianna_realty/
